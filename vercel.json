{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/compliance-evaluate",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/pm-forecast-sweep",
      "schedule": "30 17 * * *"
    }
  ],
  "builds": [
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/server.py"
    }
  ]
}
